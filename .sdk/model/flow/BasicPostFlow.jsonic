# BasicPostFlow

main: kit: flow: BasicPostFlow:
{
  entity: "post",
  kind: "basic",
  name: "BasicPostFlow",
  step: [
    {
      input: {
        ref: "post_ref01"
      }

      op: "create"
    }

    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "post_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "post_ref01",
        srcdatavar: "post_ref01_data",
        suffix: "_up0",
        textfield: "content"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-post_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "post_ref01",
        srcdatavar: "post_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "post01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-post_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "post_ref01",
        suffix: "_rm0"
      }

      match: {
        id: "post01"
      }

      op: "remove"
    }

    {
      input: {
        suffix: "_rt0"
      }

      op: "list",
      valid: [
        {
          apply: "ItemNotExists",
          def: {
            ref: "post_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPostFlow"
}